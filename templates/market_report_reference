
<style>
/* ── 전역 폰트: Notion Default / Inter (San-serif 계열) ── */
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
:root {
  --fn: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  --up:  #E24B4A;
  --dn:  #378ADD;
  --neu: var(--color-text-secondary);
}
body, div, span, td, th, a, p { font-family: var(--fn) !important; }

.hdr { display:flex; align-items:baseline; gap:10px; margin-bottom:1.8rem; padding-bottom:12px; border-bottom:0.5px solid var(--color-border-secondary); }
.hdr-title { font-size:20px; font-weight:600; font-family:var(--fn); }
.hdr-date  { font-size:12px; color:var(--color-text-secondary); font-family:var(--fn); }

.sec { margin:0 0 2rem; }
.sec-title { font-size:11px; font-weight:600; letter-spacing:.07em; text-transform:uppercase; color:var(--color-text-secondary); border-bottom:0.5px solid var(--color-border-secondary); padding-bottom:5px; margin-bottom:12px; font-family:var(--fn); }

/* ── 표 공통 ── */
.tbl { width:100%; border-collapse:collapse; font-size:13px; font-family:var(--fn); }
.tbl th {
  font-size:11px; font-weight:600; font-family:var(--fn);
  color:var(--color-text-secondary);
  background:var(--color-background-secondary);
  padding:6px 8px;
  border-bottom:0.5px solid var(--color-border-secondary);
  white-space:nowrap;
  text-align:center; /* ← 헤더 전체 가운데 정렬 */
}
.tbl th.l { text-align:left; }  /* 구분 헤더만 왼쪽 */
.tbl td {
  padding:8px 8px;
  border-bottom:0.5px solid var(--color-border-tertiary);
  color:var(--color-text-primary);
  font-weight:400; font-family:var(--fn);
  vertical-align:middle; line-height:1.5;
}
.tbl td.r { text-align:right; white-space:nowrap; }
.tbl td.c { text-align:center; }
.tbl td.bi { font-size:11px; color:var(--color-text-secondary); line-height:1.55; font-family:var(--fn); }
.tbl tr:last-child td { border-bottom:none; }
.tbl tr:hover td { background:var(--color-background-secondary); }

/* 변동 셀 */
.chg { display:flex; flex-direction:column; align-items:flex-end; gap:2px; }
.chg-val { font-size:13px; font-weight:400; white-space:nowrap; font-family:var(--fn); }
.chg-lbl { font-size:10px; color:var(--color-text-secondary); white-space:nowrap; font-family:var(--fn); }
.up  { color:var(--up); }
.dn  { color:var(--dn); }
.neu { color:var(--neu); }

/* 수급 바 */
.bar-row { display:flex; align-items:center; gap:6px; margin-bottom:4px; font-size:12px; font-family:var(--fn); }
.bar-row .nm { min-width:40px; color:var(--color-text-secondary); }
.bwrap { flex:1; height:4px; background:var(--color-border-tertiary); border-radius:2px; }
.bfill { height:100%; border-radius:2px; }
.b-buy  { background:var(--up); }
.b-sell { background:var(--dn); }
.bar-row .val { min-width:90px; text-align:right; font-size:12px; font-weight:400; font-family:var(--fn); }
.sup-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:10px; }
.sup-card { background:var(--color-background-secondary); border-radius:var(--border-radius-md); padding:11px 13px; }
.sup-card .st { font-size:11px; font-weight:600; color:var(--color-text-secondary); margin-bottom:7px; font-family:var(--fn); }

/* 차트 */
.chart-wrap { position:relative; width:100%; height:195px; margin-bottom:6px; }

/* 뉴스 */
.ntbl { width:100%; border-collapse:collapse; font-size:13px; font-family:var(--fn); }
.ntbl th {
  font-size:11px; font-weight:600; font-family:var(--fn);
  color:var(--color-text-secondary);
  background:var(--color-background-secondary);
  padding:6px 8px;
  border-bottom:0.5px solid var(--color-border-secondary);
  text-align:center; /* ← 뉴스 헤더도 가운데 */
}
.ntbl th.l { text-align:left; }
.ntbl td { padding:9px 8px; border-bottom:0.5px solid var(--color-border-tertiary); vertical-align:top; font-weight:400; font-family:var(--fn); }
.ntbl tr:last-child td { border-bottom:none; }
.td-date { white-space:nowrap; font-size:12px; color:var(--color-text-secondary); min-width:68px; }
.td-cat  { white-space:nowrap; min-width:64px; text-align:center; }
.td-ttl  { min-width:190px; max-width:215px; }
.td-ttl a { color:var(--color-text-info); text-decoration:none; font-size:12px; line-height:1.45; font-weight:400; font-family:var(--fn); }
.td-ttl a:hover { text-decoration:underline; }
.td-src  { font-size:11px; color:var(--color-text-secondary); margin-top:3px; font-family:var(--fn); }
.td-sum  { font-size:12px; color:var(--color-text-secondary); line-height:1.65; font-weight:400; font-family:var(--fn); }
.tag { display:inline-block; font-size:10px; font-weight:600; padding:2px 6px; border-radius:4px; font-family:var(--fn); }
.t-mkt  { background:var(--color-background-info);   color:var(--color-text-info); }
.t-corp { background:var(--color-background-success); color:var(--color-text-success); }
.t-mac  { background:var(--color-background-warning); color:var(--color-text-warning); }
.note { font-size:11px; color:var(--color-text-tertiary); margin-top:5px; line-height:1.7; font-family:var(--fn); }
.divider { height:0.5px; background:var(--color-border-tertiary); margin:1.5rem 0; }
</style>


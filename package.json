{
  "name": "daily-market-report",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start":        "node tools/main.js",
    "now":          "node tools/main.js --now",
    "dry-run":      "node tools/main.js --now --dry-run",
    "skip-collect": "node tools/main.js --now --skip-collect",
    "report":       "node tools/orchestrator.js --now",
    "report:dry":   "node tools/orchestrator.js --now --dry-run",
    "tf:news":      "node tools/teams/tf_news.js --date",
    "tf:crypto":    "node tools/teams/tf_crypto.js --date",
    "tf:analyst":   "node tools/teams/tf_analyst.js --date"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@notionhq/client": "^2.2.15",
    "@octokit/core": "^6.1.0",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "dayjs": "^1.11.0",
    "dotenv": "^16.0.0",
    "node-cron": "^3.0.0",
    "nodemailer": "^6.9.0"
  }
}

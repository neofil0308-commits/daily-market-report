# ── Claude API ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-여기에입력
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── 데이터 수집 API ──────────────────────────────────────
# 환율: 한국은행 OpenAPI (https://ecos.bok.or.kr)
BOK_API_KEY=여기에입력

# 뉴스: 네이버 검색 API (https://developers.naver.com)
NAVER_CLIENT_ID=여기에입력
NAVER_CLIENT_SECRET=여기에입력

# ── 발행 대상 ────────────────────────────────────────────
NOTION_API_KEY=secret_여기에입력
NOTION_PAGE_ID=여기에입력

# Gmail 발송 (보내는 계정 = 받는 계정이어도 됨)
# App 비밀번호 발급: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
GMAIL_SENDER=내계정@gmail.com
GMAIL_APP_PASSWORD=앱비밀번호16자리
GMAIL_RECIPIENT=받을계정@gmail.com

# GitHub (Notion HTML embed용 Gist 업로드)
GITHUB_TOKEN=여기에입력

# ── 설정 ─────────────────────────────────────────────────
TZ=Asia/Seoul
OUTPUT_DIR=./outputs
